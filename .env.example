# --- Gmail / OAuth ---
# Path to the Google OAuth desktop-app client secret JSON file (download from
# Google Cloud Console after enabling the Gmail API).
# Defaults to ./client_secret.json if unset.
GOOGLE_APP_CLIENT_SECRET=client_secret.json

# Gmail inbox to ingest from. Must match the account that authorizes OAuth.
EMAIL_INBOX=you@example.com

# Display name for your org (used for context in agent prompts).
ORG_NAME=

# Date floor for the initial backfill (YYYY-MM-DD). Defaults to 2022-12-01.
CUTOFF_DATE=2024-01-01

# --- Database (Postgres + pgvector) ---
# Full SQLAlchemy URL. Used by both runtime (db/singleton.py) and Alembic.
# Example: postgresql://USER:PASSWORD@HOST:5432/DBNAME
POSTGRES_CONNECTION=postgresql://postgres:CHANGE_ME@localhost:5432/replyrobin

# --- LLM Providers ---
# Google Gemini API key (note: the codebase reads the var name `GEMNI_API_KEY`).
GEMNI_API_KEY=

# --- LangSmith (optional, used by evals + @traceable in orchestrator) ---
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=replyrobin
